datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Wire {
  id            Int      @id
  sender        String
  recipient     String
  amount        String
  feeAmount     String   @default("0")
  refHash       String
  purposeCode   Int      @default(0)
  memo          String   @default("")
  status        String   @default("PENDING")
  txHash        String
  blockNumber   Int
  timestamp     DateTime
  createdAt     DateTime @default(now())
}

model WireEvent {
  id          Int      @id @default(autoincrement())
  wireId      Int
  eventType   String
  actor       String
  txHash      String
  blockNumber Int
  logIndex    Int
  data        String   @default("{}")
  timestamp   DateTime
  createdAt   DateTime @default(now())
  @@unique([txHash, logIndex])
}

model SyncState {
  id              Int    @id @default(1)
  lastBlockNumber Int    @default(0)
}

model PasskeyUser {
  id            String   @id @default(uuid())
  credentialId  String   @unique
  walletAddress String   @unique
  username      String   @unique
  createdAt     DateTime @default(now())
}

model Sponsorship {
  id            String   @id @default(uuid())
  userAddress   String
  txHash        String   @unique
  gasSavedUsd   Float
  timestamp     DateTime @default(now())
}

model GatewayBalance {
  userAddress String   @id
  balance     Float    @default(0.0)
  updatedAt   DateTime @default(now())
}

model GatewayDeposit {
  id          String   @id @default(uuid())
  userAddress String
  amount      Float
  txHash      String
  timestamp   DateTime @default(now())
}

model GatewayNanopayment {
  id               String   @id @default(uuid())
  sender           String
  recipient        String
  amount           Float
  feeAmount        Float
  memo             String   @default("")
  purposeCode      Int      @default(0)
  status           String   @default("PENDING")
  timestamp        DateTime @default(now())
  settlementTxHash String?
}

model FxTrade {
  id               String   @id @default(uuid())
  userAddress      String
  sellCurrency     String
  sellAmount       Float
  buyCurrency      String
  buyAmount        Float
  quotedRate       Float
  executedRate     Float
  slippage         Float
  txHash           String?
  timestamp        DateTime @default(now())
}

model Contact {
  id          Int      @id @default(autoincrement())
  ownerAddr   String
  name        String
  address     String
  label       String   @default("")
  isFavorite  Boolean  @default(false)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerAddr, address])
}

model Schedule {
  id          Int      @id @default(autoincrement())
  ownerAddr   String
  recipient   String
  amount      String
  purposeCode Int      @default(1)
  memo        String   @default("")
  frequency   String   // daily, weekly, biweekly, monthly
  dayOfWeek   Int?     // 0-6 for weekly
  dayOfMonth  Int?     // 1-31 for monthly
  startDate   DateTime
  endDate     DateTime?
  nextRunAt   DateTime
  status      String   @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  executions  Execution[]
}

model Execution {
  id          Int      @id @default(autoincrement())
  scheduleId  Int
  schedule    Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  wireId      Int?
  txHash      String?
  status      String   // SUCCESS, FAILED, PENDING
  error       String?
  executedAt  DateTime @default(now())
}

model Invoice {
  id          Int           @id @default(autoincrement())
  slug        String        @unique @default(uuid())
  payeeAddr   String
  payerAddr   String?
  amount      String
  currency    String        @default("USDC")
  memo        String        @default("")
  dueDate     DateTime?
  status      String        @default("DRAFT")
  wireId      Int?
  txHash      String?
  paidAt      DateTime?
  items       InvoiceItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int      @default(1)
  unitPrice   String
}

model Agent {
  id              Int      @id @default(autoincrement())
  address         String   @unique
  name            String
  reputationScore Int      @default(100)
  agentCardUri    String
  capabilities    String   // JSON string or comma-separated list
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  jobs            Job[]    @relation("AgentJobs")
}

model Job {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @default(uuid())
  title       String
  description String
  clientAddr  String
  agentAddr   String
  agent       Agent    @relation("AgentJobs", fields: [agentAddr], references: [address])
  amount      String
  status      String   @default("CREATED") // CREATED, SUBMITTED, APPROVED, DISPUTED
  proofOfWork String?
  txHash      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KycProfile {
  id          Int      @id @default(autoincrement())
  walletAddr  String   @unique
  tier        String   @default("UNVERIFIED")
  fullName    String?
  country     String?
  documentId  String?
  verifiedAt  DateTime?
  expiresAt   DateTime?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model ComplianceCheck {
  id          Int      @id @default(autoincrement())
  wireId      Int?
  walletAddr  String
  checkType   String   // SANCTIONS, PEP, ADVERSE_MEDIA
  result      String   // PASS, FAIL, REVIEW
  details     String   @default("{}")
  checkedAt   DateTime @default(now())
}

model NotificationSubscription {
  id         Int      @id @default(autoincrement())
  walletAddr String   @unique
  endpoint   String
  keys       String   // JSON string of auth/p256dh keys
  createdAt  DateTime @default(now())
}

model AgentGoal {
  id          String      @id @default(uuid())
  userAddress String
  goal        String
  provider    String      // "openai" | "deepseek"
  status      String      @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  summary     String      @default("")
  steps       AgentStep[]
  createdAt   DateTime    @default(now())
}

model AgentStep {
  id          String    @id @default(uuid())
  goalId      String
  goal        AgentGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  stepNumber  Int
  toolName    String
  description String
  status      String    @default("PENDING") // PENDING, RUNNING, SUCCESS, FAILED
  result      String    @default("") // JSON string of output
  reasoning   String    @default("")
  createdAt   DateTime  @default(now())
}

model AgentMemory {
  id          String   @id @default(uuid())
  userAddress String
  key         String
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Conversation {
  id          String        @id @default(uuid())
  userAddress String
  title       String        @default("New Conversation")
  status      String        @default("ACTIVE") // ACTIVE, ARCHIVED
  messages    ChatMessage[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user, assistant, system, tool
  content        String
  toolName       String?
  toolResult     String?
  metadata       String       @default("{}")
  createdAt      DateTime     @default(now())
}

model SavedWorkflow {
  id          String   @id @default(uuid())
  userAddress String
  name        String
  description String   @default("")
  trigger     String   @default("manual") // manual, schedule, event
  schedule    String?  // cron expression for scheduled workflows
  steps       String   @default("[]") // JSON array of workflow steps
  status      String   @default("ACTIVE") // ACTIVE, PAUSED, ARCHIVED
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Automation {
  id          String   @id @default(uuid())
  userAddress String
  workflowId  String?
  name        String
  type        String   // monitor, scheduler, trigger
  config      String   @default("{}") // JSON config for the automation
  status      String   @default("RUNNING") // RUNNING, PAUSED, COMPLETED, FAILED
  lastOutput  String   @default("")
  runCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}








