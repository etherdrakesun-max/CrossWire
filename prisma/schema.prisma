datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Wire {
  id            Int      @id
  sender        String
  recipient     String
  amount        String
  feeAmount     String   @default("0")
  refHash       String
  purposeCode   Int      @default(0)
  memo          String   @default("")
  status        String   @default("PENDING")
  txHash        String
  blockNumber   Int
  timestamp     DateTime
  createdAt     DateTime @default(now())
}

model WireEvent {
  id          Int      @id @default(autoincrement())
  wireId      Int
  eventType   String
  actor       String
  txHash      String
  blockNumber Int
  logIndex    Int
  data        String   @default("{}")
  timestamp   DateTime
  createdAt   DateTime @default(now())
  @@unique([txHash, logIndex])
}

model SyncState {
  id              Int    @id @default(1)
  lastBlockNumber Int    @default(0)
}

model PasskeyUser {
  id            String   @id @default(uuid())
  credentialId  String   @unique
  walletAddress String   @unique
  username      String   @unique
  createdAt     DateTime @default(now())
}

model Sponsorship {
  id            String   @id @default(uuid())
  userAddress   String
  txHash        String   @unique
  gasSavedUsd   Float
  timestamp     DateTime @default(now())
}

model GatewayBalance {
  userAddress String   @id
  balance     Float    @default(0.0)
  updatedAt   DateTime @default(now())
}

model GatewayDeposit {
  id          String   @id @default(uuid())
  userAddress String
  amount      Float
  txHash      String
  timestamp   DateTime @default(now())
}

model GatewayNanopayment {
  id               String   @id @default(uuid())
  sender           String
  recipient        String
  amount           Float
  feeAmount        Float
  memo             String   @default("")
  purposeCode      Int      @default(0)
  status           String   @default("PENDING")
  timestamp        DateTime @default(now())
  settlementTxHash String?
}

model FxTrade {
  id               String   @id @default(uuid())
  userAddress      String
  sellCurrency     String
  sellAmount       Float
  buyCurrency      String
  buyAmount        Float
  quotedRate       Float
  executedRate     Float
  slippage         Float
  txHash           String?
  timestamp        DateTime @default(now())
}

model Contact {
  id          Int      @id @default(autoincrement())
  ownerAddr   String
  name        String
  address     String
  label       String   @default("")
  isFavorite  Boolean  @default(false)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerAddr, address])
}


